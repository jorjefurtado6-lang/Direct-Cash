rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jorjefurtado6@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isReceiver() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        resource.data.receiverId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.pixKey ||
        resource.data.receiverPixKey == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.pixKey
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        resource.data.sponsorCode != null ||
        resource.data.inviteCode != null ||
        isAdmin()
      );
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        isReceiver() ||
        isAdmin()
      );
      
      allow list: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        isReceiver() ||
        isAdmin()
      );
      
      allow create: if isSignedIn() && (
        request.resource.data.senderId == request.auth.uid || 
        isAdmin()
      );
      
      allow update: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        isReceiver() ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }
  }
}
